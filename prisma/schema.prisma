generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Teacher { 
  id       Int     @id @default(autoincrement()) 
  email    String  @unique
  name     String
  surname  String
  password String
  
  classes  Class[]
}

model Class {
  id        Int      @id @default(autoincrement())
  name      String
  day       String
  time      String
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}